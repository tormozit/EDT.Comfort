<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

  <extension point="org.eclipse.ui.startup">
    <startup class="tormozit.edt.compare.open_object.menu.CompareEditorMenuHook"/>
  </extension>

  <extension point="org.eclipse.ui.contexts">
    <context
        id="tormozit.edt.compare.open_object.context"
        name="Редактор сравнения EDT"
        parentId="org.eclipse.ui.contexts.window"/>
  </extension>

  <extension point="org.eclipse.ui.bindings">
    <key
        commandId="tormozit.edt.compare.open_object.openObject"
        contextId="tormozit.edt.compare.open_object.context"
        schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
        sequence="F2"/>
  </extension>

  <extension point="org.eclipse.ui.commands">
    <command
        id="tormozit.edt.compare.open_object.openObject"
        name="Открыть объект"
        description="Открыть выбранный объект конфигурации в редакторе EDT"/>
    <command
        id="tormozit.edt.compare.expandExceptAddedDeleted"
        name="Развернуть все кроме добавленных/удаленных"
        description="Разворачивает дерево сравнения, пропуская добавленные и удалённые объекты"/>
  </extension>

  <extension point="org.eclipse.ui.handlers">
    <handler
        commandId="tormozit.edt.compare.open_object.openObject"
        class="tormozit.edt.compare.open_object.handlers.OpenObjectHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="com._1c.g5.v8.dt.compare.ui.editor"/>
        </with>
      </activeWhen>
    </handler>
    <handler
        commandId="tormozit.edt.compare.expandExceptAddedDeleted"
        class="tormozit.edt.compare.open_object.handlers.ExpandExceptAddedDeletedHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="com._1c.g5.v8.dt.compare.ui.editor"/>
        </with>
      </activeWhen>
    </handler>
  </extension>

  <!-- Toolbar редактора сравнения.
       Для редакторов Eclipse регистрирует IActionBars через стандартный механизм,
       поэтому toolbar: URI работает (в отличие от контекстного меню). -->
  <extension point="org.eclipse.ui.menus">
    <menuContribution
        locationURI="toolbar:com._1c.g5.v8.dt.compare.ui.editor?after=additions">
      <command
          commandId="tormozit.edt.compare.expandExceptAddedDeleted"
          tooltip="Развернуть все кроме добавленных/удаленных"
          style="push">
        <visibleWhen checkEnabled="false">
          <with variable="activeEditorId">
            <equals value="com._1c.g5.v8.dt.compare.ui.editor"/>
          </with>
        </visibleWhen>
      </command>
    </menuContribution>
  </extension>

</plugin>
