<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

  <extension point="org.eclipse.ui.startup">
    <startup class="tormozit.CompareConfigMenuHook"/>
    <startup class="tormozit.ApplicationsViewHook"/>
    <startup class="tormozit.ApplicationEditorHook"/>
    <startup class="tormozit.DataCompositionSchemaEditorHook"/> 
    <startup class="tormozit.MoxelEditorHook"/>
    <startup class="tormozit.BSLEditorMenuHook"/> 
    <startup class="tormozit.SmartOutlineHook"/> 
    <startup class="tormozit.OpenMdObjectHook"/>
    <startup class="tormozit.MenuTooltipStatusLineHook"/>  
  </extension>

  <extension point="org.eclipse.ui.contexts">
    <context
        id="tormozit.edt.compareConf.context"
        name="Редактор сравнения EDT"
        parentId="org.eclipse.ui.contexts.window"/>
  </extension>

  <extension point="org.eclipse.ui.bindings">
    <key
          commandId="tormozit.edt.compareConf.openObject"
          contextId="tormozit.edt.compareConf.context"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="F2">
    </key>
    <key
          commandId="tormozit.edt.compareConf.showInNavigator"
          contextId="tormozit.edt.compareConf.context"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="M1+T">
    </key>
    <key
          commandId="tormozit.edt.JumpToRef"
          contextId="org.eclipse.ui.contexts.window"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="M1+F12">
    </key>
    <key
          commandId="tormozit.edt.CopyRef"
          contextId="org.eclipse.ui.contexts.window"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="M1+F11">
    </key>
  </extension>

  <extension point="org.eclipse.ui.commands">
    <command
        id="tormozit.edt.compareConf.openObject"
        name="Открыть объект"
        description="Открыть выбранный объект конфигурации в редакторе (Tormozit)"/>
     <command
        id="tormozit.edt.compareConf.showInNavigator"
        name="Показать в навигаторе"
        description="Показать выбранный объект конфигурации в навигаторе (Tormozit)"/>
     <command
            id="tormozit.edt.JumpToRef"
            name="Перейти"
            description="Перейти по ссылке из буфера обмена (Tormozit)"/>
    <command
            id="tormozit.edt.CopyRef"
            name="Ссылка"
            description="Копировать ссылку на текущий объект или строку модуля (Tormozit)"/>
  </extension>

  <extension point="org.eclipse.ui.handlers">
    <handler
        commandId="tormozit.edt.compareConf.openObject"
        class="tormozit.ExecutableExtensionFactory:tormozit.CompareConfigOpenObjectHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="com._1c.g5.v8.dt.compare.ui.editor"/>
        </with>
      </activeWhen>
    </handler>
    <handler
        commandId="tormozit.edt.compareConf.showInNavigator"
        class="tormozit.ExecutableExtensionFactory:tormozit.CompareConfigShowInNavigatorHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="com._1c.g5.v8.dt.compare.ui.editor"/>
        </with>
      </activeWhen>
    </handler>
    <handler
        class="tormozit.ExecutableExtensionFactory:tormozit.GoToDefinition"
        commandId="tormozit.edt.JumpToRef">
     </handler>
    <handler
        class="tormozit.ExecutableExtensionFactory:tormozit.GetRef"
        commandId="tormozit.edt.CopyRef">
     </handler>
  </extension>

  <extension point="org.eclipse.ui.menus">
      <menuContribution locationURI="toolbar:org.eclipse.ui.main.toolbar?after=additions">
         <toolbar id="tormozit.edt.toolbar.mainGroup">
            <command
              commandId="tormozit.edt.JumpToRef"
              tooltip="Перейти по ссылке из буфера обмена (Tormozit)"
              style="push">
            </command>
            <command
              commandId="tormozit.edt.CopyRef"
              tooltip="Копировать ссылку на текущий объект или строку модуля (Tormozit)"
              style="push">
            </command>
         </toolbar>
      </menuContribution>
   </extension>

  <!-- Страница настроек автооткрытия подсказки BSL -->
  <extension point="org.eclipse.ui.preferencePages">
    <page
        category="com._1c.g5.v8.dt.bsl.Bsl"
        class="tormozit.ContentAssistPreferencePage"
        id="tormozit.edt.contentAssistAutoOpen.preferencePages"
        name="Автооткрытие подсказки"/>
  </extension>

  <!-- Инициализатор значений по умолчанию для настроек автооткрытия -->
  <extension point="org.eclipse.core.runtime.preferences">
    <initializer
        class="tormozit.ContentAssistInitializer"/>
  </extension>

</plugin>
