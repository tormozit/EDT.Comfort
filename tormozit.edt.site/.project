<?xml version="1.0" encoding="UTF-8"?>
<projectDescription>
	<name>tormozit.edt.site</name>
	<comment></comment>
	<projects>
	</projects>
	<buildSpec>
		<buildCommand>
			<name>org.eclipse.ant.core.antBuilder</name>
			<triggers>clean,full,incremental,</triggers>
			<arguments>
				<dictionary>
					<key>org.eclipse.ant.ui.ANT_SCRIPT</key>
					<value>$P{project_loc:/tormozit.edt.site}/../sync-version-ant.xml</value>
				</dictionary>
				<dictionary>
					<key>org.eclipse.ant.ui.DEFAULT_TARGET</key>
					<value>sync</value>
				</dictionary>
				<dictionary>
					<key>org.eclipse.ant.ui.AUTO_BUILD</key>
					<value>true</value>
				</dictionary>
			</arguments>
		</buildCommand>
		<buildCommand>
			<name>org.eclipse.pde.UpdateSiteBuilder</name>
			<arguments>
			</arguments>
		</buildCommand>
	</buildSpec>
	<natures>
		<nature>org.eclipse.pde.UpdateSiteNature</nature>
	</natures>
</projectDescription>
