<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

  <extension point="org.eclipse.ui.startup">
    <startup class="tormozit.CompareConfigMenuHook"/>
    <startup class="tormozit.ApplicationsViewHook"/>
    <startup class="tormozit.ApplicationEditorHook"/>
    <startup class="tormozit.DataCompositionSchemaEditorHook"/> 
    <startup class="tormozit.MoxelEditorHook"/>
    <startup class="tormozit.BSLEditorMenuHook"/> 
    <startup class="tormozit.TextEditorRightClickCaretHook"/>
    <startup class="tormozit.TextEditorMenuHook"/>
    <startup class="tormozit.QueryTextEditDialogHook"/>
    <startup class="tormozit.FormEditorHook"/>
    <startup class="tormozit.IrKeyBindingHook"/>
    <startup class="tormozit.PriorityGlobalKeyBindingHook"/>
    <startup class="tormozit.ComfortKeysPageHook"/>
    <startup class="tormozit.IrFormatTextKeyDiagHook"/>
    <startup class="tormozit.SmartOutlineHook"/>
    <startup class="tormozit.NavigatorFilterHook"/>
    <startup class="tormozit.NavigatorShowInExplorerMenuHook"/>
    <startup class="tormozit.InfobasesViewHook"/>
    <startup class="tormozit.OpenMdObjectHook"/>
    <startup class="tormozit.MenuTooltipStatusLineHook"/>
    <startup class="tormozit.RecentPlacesTracker"/>
    <startup class="tormozit.PropertySheetHook"/>
    <startup class="tormozit.ChoiceParametersHook"/>
    <startup class="tormozit.PredefinedSelectionDialogHook"/>
    <startup class="tormozit.DebugViewsMenuHook"/>
    <startup class="tormozit.DebugValuesInspectHook"/>
    <startup class="tormozit.DebugInspectorHook"/>
    <startup class="tormozit.InfobaseSyncQuestionDialogHook"/>
  </extension>

  <extension point="org.eclipse.ui.contexts">
    <context
        id="tormozit.compareConf.context"
        name="Редактор сравнения EDT"
        parentId="org.eclipse.ui.contexts.window"/>
  </extension>

  <extension point="org.eclipse.ui.bindings">
    <key
          commandId="tormozit.compareConf.openObject"
          contextId="tormozit.compareConf.context"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="F2">
    </key>
    <key
          commandId="tormozit.compareConf.showInNavigator"
          contextId="tormozit.compareConf.context"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="M1+T">
    </key>
    <key
          commandId="tormozit.GoToDefinition"
          contextId="org.eclipse.ui.contexts.window"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="M1+F12">
    </key>
    <key
          commandId="tormozit.CopyRef"
          contextId="org.eclipse.ui.contexts.window"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="M1+F11">
    </key>
    <key
          commandId="tormozit.RecentPlaces"
          contextId="org.eclipse.ui.contexts.window"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="M1+3">
    </key>
    <key
          commandId="tormozit.OpenConfigurationObject"
          contextId="org.eclipse.ui.contexts.window"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="M1+2">
    </key>
    <key
          commandId="tormozit.PasteWithCompare"
          contextId="org.eclipse.ui.contexts.window"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="M1+M3+V">
    </key>
    <key
          commandId="tormozit.ModuleOutline"
          contextId="org.eclipse.xtext.ui.XtextEditorScope"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="M1+Ё">
    </key>
    <key
          commandId="tormozit.IrMethodConstructor"
          contextId="org.eclipse.xtext.ui.XtextEditorScope"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="M1+M2+M">
    </key>
    <key
          commandId="tormozit.IrEmbeddedText"
          contextId="org.eclipse.xtext.ui.XtextEditorScope"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="M1+M2+E">
    </key>
    <key
          commandId="tormozit.IrFormatText"
          contextId="org.eclipse.xtext.ui.XtextEditorScope"
          schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
          sequence="M3+M2+F">
    </key>
  </extension>

  <extension point="org.eclipse.ui.commands">
    <category
        id="tormozit.commands.global"
        name="Комфорт"
        description="Команды плагина Комфорт"/>
    <command
        id="tormozit.compareConf.openObject"
        name="Открыть объект"
        categoryId="tormozit.commands.global"
        description="Открыть выбранный объект конфигурации в редакторе (Комфорт)"/>
     <command
        id="tormozit.compareConf.showInNavigator"
        name="Показать в навигаторе"
        categoryId="tormozit.commands.global"
        description="Показать выбранный объект конфигурации в навигаторе (Комфорт)"/>
     <command
        id="tormozit.GoToDefinition"
        name="Перейти к определению"
        categoryId="tormozit.commands.global"
        description="Перейти к определению. Приоритет над привязками EDT (в т.ч. редактор форм). Не рекомендуется изменять. Настраивайте только «В окнах». Остальные контексты не редактируйте. (Комфорт)"/>
    <command
        id="tormozit.CopyRef"
        name="Копировать ссылку"
        categoryId="tormozit.commands.global"
        description="Копировать ссылку на объект или строку модуля. Приоритет над EDT. Настраивайте только «В окнах». Остальные контексты не редактируйте. (Комфорт)"/>
    <command
        id="tormozit.RecentPlaces"
        name="Последние места"
        categoryId="tormozit.commands.global"
        description="Открыть список последних посещённых методов и объектов метаданных (Комфорт)"/>
    <command
        id="tormozit.OpenConfigurationObject"
        name="Открыть объект конфигурации"
        categoryId="tormozit.commands.global"
        description="Диалог выбора объекта метаданных. То же, что штатная команда EDT; сочетание настраивается в Клавиши, контекст «В окнах» (Комфорт)"/>
    <command
        id="tormozit.navigator.showInExplorer"
        name="Показать в проводнике"
        categoryId="tormozit.commands.global"
        description="Открыть проводник ОС на файле или папке выбранного элемента навигатора (Комфорт)"/>
    <command
        id="tormozit.PasteWithCompare"
        name="Вставить со сравнением"
        categoryId="tormozit.commands.global"
        description="Сравнить выделение с буфером и вставить отредактированный текст. Сочетание настраивается в Клавиши, контекст «В окнах»; срабатывает при фокусе в редактируемом текстовом поле (Комфорт)"/>
    <command
        id="tormozit.ModuleOutline"
        name="Быстрая схема модуля"
        categoryId="tormozit.commands.global"
        description="Всплывающая схема модуля. То же, что одноименный пункт контекстного меню и штатный «Быстрый план» / Ctrl+O (Комфорт)"/>
    <command
        id="tormozit.IrMethodConstructor"
        name="Конструктор метода ИР"
        categoryId="tormozit.commands.global"
        description="Открыть конструктор метода приложения ИР. Активно только при подключённом ИР. Настраивайте только «Редактирование источника Xtext». Остальные контексты не редактируйте. (Комфорт)"/>
    <command
        id="tormozit.IrEmbeddedText"
        name="Вложенный текст ИР"
        categoryId="tormozit.commands.global"
        description="Открыть строковый литерал BSL в редакторе текста ИР. Активно только при подключённом ИР. Настраивайте только «Редактирование источника Xtext». Остальные контексты не редактируйте. (Комфорт)"/>
    <command
        id="tormozit.IrFormatText"
        name="Форматировать текст ИР"
        categoryId="tormozit.commands.global"
        description="Форматировать выделенный текст модуля или текст запроса через приложение ИР. Активно только при подключённом ИР. Настраивайте только «Редактирование источника Xtext». Остальные контексты не редактируйте. (Комфорт)"/>
  </extension>

  <extension point="org.eclipse.ui.handlers">
    <handler
        commandId="tormozit.compareConf.openObject"
        class="tormozit.ExecutableExtensionFactory:tormozit.CompareConfigOpenObjectHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="com._1c.g5.v8.dt.compare.ui.editor"/>
        </with>
      </activeWhen>
    </handler>
    <handler
        commandId="tormozit.compareConf.showInNavigator"
        class="tormozit.ExecutableExtensionFactory:tormozit.CompareConfigShowInNavigatorHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="com._1c.g5.v8.dt.compare.ui.editor"/>
        </with>
      </activeWhen>
    </handler>
    <handler
        class="tormozit.ExecutableExtensionFactory:tormozit.GoToDefinition"
        commandId="tormozit.GoToDefinition">
     </handler>
    <handler
        class="tormozit.ExecutableExtensionFactory:tormozit.GoToDefinition"
        commandId="tormozit.JumpFromClipboard">
     </handler>  
     <handler
        class="tormozit.ExecutableExtensionFactory:tormozit.GetRef"
        commandId="tormozit.CopyRef">
     </handler>
    <handler
        class="tormozit.ExecutableExtensionFactory:tormozit.RecentPlacesHandler"
        commandId="tormozit.RecentPlaces">
     </handler>
    <handler
        class="tormozit.ExecutableExtensionFactory:tormozit.OpenConfigurationObjectHandler"
        commandId="tormozit.OpenConfigurationObject">
     </handler>
    <handler
        class="tormozit.ExecutableExtensionFactory:tormozit.NavigatorShowInExplorerHandler"
        commandId="tormozit.navigator.showInExplorer">
      <activeWhen>
        <with variable="activePartId">
          <equals value="com._1c.g5.v8.dt.ui2.navigator"/>
        </with>
      </activeWhen>
    </handler>
    <handler
        class="tormozit.ExecutableExtensionFactory:tormozit.PasteWithCompareHandler"
        commandId="tormozit.PasteWithCompare">
    </handler>
    <handler
        class="tormozit.ExecutableExtensionFactory:tormozit.ModuleOutlineHandler"
        commandId="tormozit.ModuleOutline">
      <activeWhen>
        <with variable="activeContexts">
          <iterate operator="or">
            <equals value="org.eclipse.xtext.ui.XtextEditorScope"/>
          </iterate>
        </with>
      </activeWhen>
    </handler>
    <handler
        class="tormozit.ExecutableExtensionFactory:tormozit.IrMethodConstructorHandler"
        commandId="tormozit.IrMethodConstructor">
      <activeWhen>
        <with variable="activeContexts">
          <iterate operator="or">
            <equals value="org.eclipse.xtext.ui.XtextEditorScope"/>
          </iterate>
        </with>
      </activeWhen>
    </handler>
    <handler
        class="tormozit.ExecutableExtensionFactory:tormozit.EditEmbeddedTextCommandHandler"
        commandId="tormozit.IrEmbeddedText">
      <activeWhen>
        <with variable="activeContexts">
          <iterate operator="or">
            <equals value="org.eclipse.xtext.ui.XtextEditorScope"/>
          </iterate>
        </with>
      </activeWhen>
    </handler>
    <handler
        class="tormozit.ExecutableExtensionFactory:tormozit.IrFormatTextCommandHandler"
        commandId="tormozit.IrFormatText">
    </handler>
  </extension>

  <extension point="org.eclipse.ui.menus">
      <menuContribution locationURI="toolbar:org.eclipse.ui.main.toolbar?after=additions">
         <toolbar id="tormozit.toolbar.mainGroup">
            <command
              commandId="tormozit.JumpFromClipboard"
              label = "Перейти"
              tooltip="Перейти по ссылке из буфера обмена (Комфорт)"
              style="push">
            </command>
            <command
              commandId="tormozit.CopyRef"
              label = "Ссылка"
              tooltip="Копировать ссылку; это сочетание команды имеет приоритет над локальными привязками EDT (Комфорт)"
              style="push">
            </command>
            <command
              commandId="tormozit.RecentPlaces"
              label = "Последние"
              tooltip="Последние посещённые методы и объекты метаданных (Комфорт)"
              style="push">
            </command>
         </toolbar>
      </menuContribution>
   </extension>

  <extension point="org.eclipse.ui.views">
    <category
        id="tormozit.views"
        name="Комфорт"/>
    <view
        allowMultiple="false"
        category="tormozit.views"
        class="tormozit.ContentAssistLogView"
        id="tormozit.ContentAssistLogView"
        name="Журнал Комфорт"
        restorable="true"/>
  </extension>

  <extension point="org.eclipse.ui.preferencePages">
    <page
        class="tormozit.ComfortPreferencePage"
        id="tormozit.ComfortPreferencePages"
        name="Комфорт"/>
  </extension>

  <extension point="org.eclipse.core.runtime.preferences">
    <initializer
        class="tormozit.ComfortInitializer"/>
  </extension>

</plugin>
